generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  companyName         String
  role                UserRole
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assets              Asset[]
  dealsCreated        Deal[]
  passwordResetTokens PasswordResetToken[]
  requests            Request[]
}

model Asset {
  id                   String      @id @default(cuid())
  ownerUserId          String
  assetTitle           String
  category             String
  subcategory          String?
  manufacturer         String?
  modelName            String?
  quantity             Int
  unit                 String?
  conditionGrade       String
  locationRegion       String
  locationDetail       String?
  askingPrice          Decimal?    @db.Decimal(18, 2)
  priceNegotiable      Boolean     @default(false)
  description          String?
  imageUrls            String[]
  dismantlingRequired  Boolean     @default(false)
  transportRequired    Boolean     @default(false)
  installationRequired Boolean     @default(false)
  status               AssetStatus @default(PENDING_REVIEW)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  manufacturedMonth    Int?
  manufacturedYear     Int?
  purchasePrice        Decimal?    @db.Decimal(18, 2)
  purchasedAt          DateTime?
  purchasedFrom        String?
  serviceOptions       String[]
  owner                User        @relation(fields: [ownerUserId], references: [id])
  deals                Deal[]

  @@index([status])
  @@index([ownerUserId])
}

model Request {
  id                   String        @id @default(cuid())
  requesterUserId      String
  requestTitle         String
  category             String
  subcategory          String?
  desiredQuantity      Int
  budgetMin            Decimal?      @db.Decimal(18, 2)
  budgetMax            Decimal?      @db.Decimal(18, 2)
  preferredRegion      String
  neededByDate         DateTime?
  urgencyLevel         UrgencyLevel  @default(MEDIUM)
  transportRequired    Boolean       @default(false)
  installationRequired Boolean       @default(false)
  description          String?
  contactPhone         String?
  status               RequestStatus @default(PENDING_REVIEW)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deals                Deal[]
  requester            User          @relation(fields: [requesterUserId], references: [id])

  @@index([status])
  @@index([requesterUserId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Deal {
  id               String     @id @default(cuid())
  assetId          String?
  requestId        String?
  createdByAdminId String
  dealTitle        String
  status           DealStatus @default(NEW)
  expectedValue    Decimal?   @db.Decimal(18, 2)
  finalValue       Decimal?   @db.Decimal(18, 2)
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  buyerCompany     String?
  buyerName        String?
  closedAt         DateTime?
  isHistorical     Boolean    @default(false)
  sellerCompany    String?
  sellerName       String?
  asset            Asset?     @relation(fields: [assetId], references: [id])
  createdBy        User       @relation(fields: [createdByAdminId], references: [id])
  request          Request?   @relation(fields: [requestId], references: [id])

  @@index([status])
  @@index([assetId])
  @@index([requestId])
}

enum UserRole {
  ADMIN
  USER
}

enum AssetStatus {
  PENDING_REVIEW
  ACTIVE
  MATCHED
  SOLD
  WITHDRAWN
}

enum RequestStatus {
  PENDING_REVIEW
  ACTIVE
  MATCHED
  CLOSED
  WITHDRAWN
}

enum DealStatus {
  NEW
  REVIEWING
  MATCHED
  NEGOTIATING
  WON
  LOST
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}
