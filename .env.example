# ──────────────────────────────────────────────
# ROOT 환경변수 설정 가이드
# 운영 배포 전 반드시 모든 값을 확인하세요.
# ──────────────────────────────────────────────

# ── 데이터베이스 ──
DATABASE_URL="postgresql://USER:PASSWORD@host:5432/root_db"
DIRECT_URL="postgresql://USER:PASSWORD@host:5432/root_db"

# ── 인증 ──
# [필수] 운영 환경에서 반드시 변경하세요! (최소 32자 랜덤 문자열)
# 생성 예시: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_USE_STRONG_RANDOM_SECRET"

# ── 이메일 (Resend) ──
RESEND_API_KEY="re_xxxxxxxxxxxxx"
# [필수] 운영 도메인의 이메일 주소로 변경 (resend.dev는 테스트용)
EMAIL_FROM="ROOT <noreply@yourdomain.com>"

# ── 이미지 스토리지 (Supabase) ──
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxxxxxx"

# ── 앱 설정 ──
# [필수] 운영 도메인 URL로 변경 (이메일 내 링크에 사용됨)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"
